{
  "name": "msdlc",
  "version": "0.1.0",
  "description": "Stack-agnostic delivery pipeline: spec → architect → planner → dev-backend/dev-frontend (parallel, file-disjoint) → qc-designer/qc-executor → doc-syncer. Project specifics come from .claude/profile.md, not hardcoded.",
  "author": { "name": "minhhv" },
  "keywords": ["pipeline", "agents", "orchestration", "qc", "architecture", "planner"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/block-read-secrets.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/block-bash-dangerous.sh\""
          }
        ]
      }
    ]
  }
}
